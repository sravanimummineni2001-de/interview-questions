SELECT FEMALE_COUNT,DEPTNAME FROM( 
SELECT SUM(CASE WHEN GENDER='M' THEN 1 ELSE 0 END) AS MALE_COUNT,
SUM(CASE WHEN GENDER='F' THEN 1 ELSE 0 END) AS FEMALE_COUNT , D.DEPTNAME
FROM EMPLOYEE E JOIN DEPARTMENT D ON E.DEPTID=D.DEPTID GROUP BY D.DEPTNAME
) R
WHERE FEMALE_COUNT> MALE_COUNT
